#!/usr/bin/env bash
# sentinel — Run package manager / git / download / archive commands with ClamAV scanning
#
# Usage:
#   sentinel npm install
#   sentinel composer install
#   sentinel git clone <url> [dir]
#   sentinel git pull
#   sentinel curl -o file.zip https://example.com/file.zip
#   sentinel wget https://example.com/file.zip
#   sentinel tar xf archive.tar.gz
#   sentinel unzip archive.zip
#   sentinel 7z x archive.7z
#
# Dependencies: clamav (clamscan), npm or composer

set -euo pipefail

QUARANTINE_DIR="${SENTINEL_QUARANTINE:-/tmp/sentinel-quarantine}"
CLAM_OPTS="${SENTINEL_CLAM_OPTS:---infected --suppress-ok-results --heuristic-alerts --heuristic-scan-precedence --alert-phishing-cloak --alert-phishing-ssl --detect-pua}"
SKIP_CLAM="${SENTINEL_SKIP_CLAM:-0}"
SKIP_AUDIT="${SENTINEL_SKIP_AUDIT:-0}"

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

log()  { echo -e "${BOLD}[sentinel]${RESET} $*"; }
ok()   { echo -e "${GREEN}[sentinel] $*${RESET}"; }
warn() { echo -e "${YELLOW}[sentinel] WARNING: $*${RESET}"; }
fail() { echo -e "${RED}[sentinel] FAILED: $*${RESET}"; }

require() {
    if ! command -v "$1" &>/dev/null; then
        warn "$1 not found — skipping ${2:-that step}"
        return 1
    fi
}

# Scan a file or directory with ClamAV. Works for both.
run_clamscan() {
    local path="$1"
    local label="$2"

    if [[ "$SKIP_CLAM" == "1" ]]; then
        warn "ClamAV scan skipped (SENTINEL_SKIP_CLAM=1)"
        return 0
    fi

    if ! require clamscan "ClamAV scan"; then return 0; fi

    if [[ ! -e "$path" ]]; then
        warn "'${path}' not found, skipping ClamAV scan"
        return 0
    fi

    log "Scanning ${label} with ClamAV..."
    mkdir -p "$QUARANTINE_DIR"

    # -r recurses directories; passing -r with a single file is a no-op
    # shellcheck disable=SC2086
    if clamscan -r "$path" $CLAM_OPTS --move="$QUARANTINE_DIR"; then
        ok "ClamAV: no threats found in ${label}"
    else
        local exit_code=$?
        if [[ $exit_code -eq 1 ]]; then
            fail "ClamAV: threats found in ${label}! Infected files moved to ${QUARANTINE_DIR}"
            fail "Review quarantined files before proceeding."
            return 1
        else
            warn "ClamAV exited with code ${exit_code} (scan error)"
        fi
    fi
}

run_npm_audit() {
    if [[ "$SKIP_AUDIT" == "1" ]]; then
        warn "npm audit skipped (SENTINEL_SKIP_AUDIT=1)"
        return 0
    fi

    if ! require npm "npm audit"; then return 0; fi

    log "Running npm audit..."
    if npm audit; then
        ok "npm audit: no vulnerabilities found"
    else
        warn "npm audit reported vulnerabilities — run 'npm audit fix' to resolve"
    fi
}

run_composer_audit() {
    if [[ "$SKIP_AUDIT" == "1" ]]; then
        warn "composer audit skipped (SENTINEL_SKIP_AUDIT=1)"
        return 0
    fi

    if ! require composer "composer audit"; then return 0; fi

    log "Running composer audit..."
    if composer audit; then
        ok "composer audit: no vulnerabilities found"
    else
        warn "composer audit reported vulnerabilities"
    fi
}

# Scan script files that composer executed during install/update.
# PHP callables (Vendor\Pkg::method) and @-aliases live inside vendor/ which is
# already scanned. We only need to scan entries that are explicit file paths.
scan_composer_scripts() {
    if [[ "$SKIP_CLAM" == "1" ]]; then return 0; fi

    if ! command -v jq &>/dev/null; then
        warn "jq not found — skipping composer script file scan (install jq for full coverage)"
        return 0
    fi

    local -a targets=()
    local jq_root='
        .scripts // {} | to_entries[] | .value |
        if type == "array" then .[] else . end |
        select(type == "string") |
        select(startswith("@") | not) |
        select(contains("::") | not)
    '
    local jq_installed='
        (.packages // .) | .[] | .scripts // {} | to_entries[] | .value |
        if type == "array" then .[] else . end |
        select(type == "string") |
        select(startswith("@") | not) |
        select(contains("::") | not)
    '

    # Emit script entry strings from a JSON file.
    _emit() {
        local file="$1" kind="$2"   # kind: root | installed
        [[ -f "$file" ]] || return 0
        local expr="$jq_root"
        [[ "$kind" == "installed" ]] && expr="$jq_installed"
        jq -r "$expr" "$file" 2>/dev/null
    }

    _collect() {
        local file="$1" kind="$2"
        [[ -f "$file" ]] || return 0
        while IFS= read -r entry; do
            local cmd="${entry%% *}"
            if [[ "$cmd" == /* || "$cmd" == ./* || "$cmd" == ../* ]] && [[ -f "$cmd" ]]; then
                targets+=("$cmd")
            fi
        done < <(_emit "$file" "$kind")
    }

    _collect "./composer.json"                      "root"
    _collect "./vendor/composer/installed.json"     "installed"

    [[ ${#targets[@]} -eq 0 ]] && return 0

    # Deduplicate
    local -A seen=()
    local -a unique=()
    for t in "${targets[@]}"; do
        if [[ -z "${seen[$t]+x}" ]]; then
            seen[$t]=1
            unique+=("$t")
        fi
    done

    local failed=0
    log "Scanning ${#unique[@]} post-install script file(s)..."
    for f in "${unique[@]}"; do
        run_clamscan "$f" "composer script: ${f}" || failed=1
    done
    return $failed
}

# Scan files written outside node_modules/ and .git/ during an npm install/update.
# Catches postinstall scripts that drop files into the project tree (dist/, public/, etc.).
scan_npm_project_files() {
    local since_file="${1:-}"
    [[ "$SKIP_CLAM" == "1" ]] && return 0
    [[ -z "$since_file" || ! -f "$since_file" ]] && return 0

    if ! require clamscan "ClamAV scan"; then return 0; fi

    local -a new_files=()
    while IFS= read -r f; do
        new_files+=("$f")
    done < <(find . -newer "$since_file" -type f \
        -not -path './node_modules/*' \
        -not -path './.git/*' \
        2>/dev/null)

    [[ ${#new_files[@]} -eq 0 ]] && return 0

    log "Scanning ${#new_files[@]} file(s) written to project tree during install..."
    mkdir -p "$QUARANTINE_DIR"

    # shellcheck disable=SC2086
    if clamscan $CLAM_OPTS --move="$QUARANTINE_DIR" "${new_files[@]}"; then
        ok "ClamAV: no threats found in project files (${#new_files[@]} file(s))"
    else
        local exit_code=$?
        if [[ $exit_code -eq 1 ]]; then
            fail "ClamAV: threats found in project files! Infected files moved to ${QUARANTINE_DIR}"
            return 1
        else
            warn "ClamAV exited with code ${exit_code} (scan error)"
        fi
    fi
}

# Scan files written outside vendor/ during a composer install/update.
# Catches post-install scripts that publish to config/, resources/, lang/,
# public/, database/migrations/, or any other project directory.
scan_composer_project_files() {
    local since_file="${1:-}"
    [[ "$SKIP_CLAM" == "1" ]] && return 0
    [[ -z "$since_file" || ! -f "$since_file" ]] && return 0

    if ! require clamscan "ClamAV scan"; then return 0; fi

    local -a new_files=()
    while IFS= read -r f; do
        new_files+=("$f")
    done < <(find . -newer "$since_file" -type f \
        -not -path './vendor/*' \
        -not -path './.git/*' \
        2>/dev/null)

    [[ ${#new_files[@]} -eq 0 ]] && return 0

    log "Scanning ${#new_files[@]} file(s) written to project tree during install..."
    mkdir -p "$QUARANTINE_DIR"

    # shellcheck disable=SC2086
    if clamscan $CLAM_OPTS --move="$QUARANTINE_DIR" "${new_files[@]}"; then
        ok "ClamAV: no threats found in project files (${#new_files[@]} file(s))"
    else
        local exit_code=$?
        if [[ $exit_code -eq 1 ]]; then
            fail "ClamAV: threats found in project files! Infected files moved to ${QUARANTINE_DIR}"
            return 1
        else
            warn "ClamAV exited with code ${exit_code} (scan error)"
        fi
    fi
}

# ── Argument parsers ──────────────────────────────────────────────────────────

# Resolve the target directory for git clone from its argument list.
# Handles: git clone <url>, git clone <url> <dir>, git clone [opts] <url> [dir]
git_clone_target_dir() {
    local args=("$@")
    local i

    local positional=()
    for (( i=0; i<${#args[@]}; i++ )); do
        local arg="${args[$i]}"
        if [[ "$arg" == --* ]]; then
            case "$arg" in
                --branch|--depth|--origin|--reference|--reference-if-able|\
                --separate-git-dir|--upload-pack|--config|--jobs)
                    (( i++ )) || true ;;
            esac
        elif [[ "$arg" == -* && ${#arg} -eq 2 ]]; then
            case "$arg" in
                -b|-o|-u|-j) (( i++ )) || true ;;
            esac
        else
            positional+=("$arg")
        fi
    done

    if [[ ${#positional[@]} -ge 2 ]]; then
        echo "${positional[1]}"
    elif [[ ${#positional[@]} -eq 1 ]]; then
        local url="${positional[0]}"
        url="${url%/}"
        url="${url%.git}"
        basename "$url"
    else
        echo "."
    fi
}

# Resolve curl's output file from its arguments.
# Returns "" if curl is writing to stdout (no scan needed).
curl_output_path() {
    local args=("$@")
    local i has_remote_name=0

    for (( i=0; i<${#args[@]}; i++ )); do
        local arg="${args[$i]}"
        case "$arg" in
            -o|--output)
                (( i++ )) || true
                echo "${args[$i]:-}"
                return
                ;;
            --output=*)
                echo "${arg#*=}"
                return
                ;;
            -O|--remote-name|-J|--remote-header-name)
                has_remote_name=1
                ;;
        esac
    done

    if [[ $has_remote_name -eq 1 ]]; then
        # Prefer an explicit URL argument
        for (( i=${#args[@]}-1; i>=0; i-- )); do
            local arg="${args[$i]}"
            if [[ "$arg" == http://* || "$arg" == https://* || "$arg" == ftp://* ]]; then
                local name="${arg%%[?#]*}"
                name="${name%/}"
                basename "$name"
                return
            fi
        done
        # Fallback: last non-flag argument
        for (( i=${#args[@]}-1; i>=0; i-- )); do
            local arg="${args[$i]}"
            if [[ "$arg" != -* ]]; then
                local name="${arg%%[?#]*}"
                name="${name%/}"
                basename "$name"
                return
            fi
        done
    fi

    echo ""
}

# Resolve wget's scan target (file or directory) from its arguments.
# Returns "" if wget is writing to stdout (no scan needed).
wget_scan_target() {
    local args=("$@")
    local i output="" prefix=""

    for (( i=0; i<${#args[@]}; i++ )); do
        local arg="${args[$i]}"
        case "$arg" in
            -O|--output-document)
                (( i++ )) || true
                output="${args[$i]:-}"
                ;;
            --output-document=*)
                output="${arg#*=}"
                ;;
            -P|--directory-prefix)
                (( i++ )) || true
                prefix="${args[$i]:-}"
                ;;
            --directory-prefix=*)
                prefix="${arg#*=}"
                ;;
        esac
    done

    # Explicit -O takes priority
    if [[ -n "$output" ]]; then
        [[ "$output" == "-" ]] && echo "" && return  # stdout, skip scan
        echo "$output"
        return
    fi

    # -P: scan that directory (wget saves files there)
    if [[ -n "$prefix" ]]; then
        echo "$prefix"
        return
    fi

    # Derive filename from a proper URL only when it has a real path component.
    # URLs like https://example.com/ or bare hostnames like www.google.com save
    # as index.html, which we can't predict — fall back to scanning cwd.
    for (( i=${#args[@]}-1; i>=0; i-- )); do
        local arg="${args[$i]}"
        if [[ "$arg" == http://* || "$arg" == https://* || "$arg" == ftp://* ]]; then
            local url_no_proto="${arg#*://}"    # strip scheme://
            if [[ "$url_no_proto" == */* ]]; then
                local path_part="${url_no_proto#*/}"   # everything after first /
                path_part="${path_part%%[?#]*}"        # strip query/fragment
                path_part="${path_part%/}"             # strip trailing slash
                local name
                name="$(basename "$path_part")"
                if [[ -n "$name" && "$name" != "." ]]; then
                    echo "$name"
                    return
                fi
            fi
            break  # URL with no usable path → wget saves index.html → scan cwd
        fi
    done

    echo "."
}

# Resolve tar's extraction target directory.
tar_target_dir() {
    local args=("$@")
    local i
    for (( i=0; i<${#args[@]}; i++ )); do
        case "${args[$i]}" in
            -C|--directory)
                (( i++ )) || true
                echo "${args[$i]:-}"
                return
                ;;
            --directory=*)
                echo "${args[$i]#*=}"
                return
                ;;
        esac
    done
    echo "."
}

# Resolve unzip's extraction target directory.
unzip_target_dir() {
    local args=("$@")
    local i
    for (( i=0; i<${#args[@]}; i++ )); do
        case "${args[$i]}" in
            -d)
                (( i++ )) || true
                echo "${args[$i]:-}"
                return
                ;;
        esac
    done
    echo "."
}

# Resolve 7z/7za extraction target directory.
# 7z uses -o with no space: -o/path/to/dir
sevenz_target_dir() {
    local args=("$@")
    for arg in "${args[@]}"; do
        case "$arg" in
            -o?*)
                echo "${arg#-o}"
                return
                ;;
        esac
    done
    echo "."
}

# ── Handlers ──────────────────────────────────────────────────────────────────

handle_git() {
    local git_cmd="${1:-}"
    shift || true

    log "Running: git ${git_cmd} $*"
    command git "$git_cmd" "$@"
    local exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        fail "git ${git_cmd} failed (exit ${exit_code})"
        exit $exit_code
    fi

    local scan_dir
    case "$git_cmd" in
        clone)
            scan_dir="$(git_clone_target_dir "$@")"
            ;;
        pull|fetch)
            scan_dir="."
            ;;
        *)
            exit 0
            ;;
    esac

    echo ""
    log "git ${git_cmd} complete — running ClamAV scan on '${scan_dir}'..."
    echo ""

    run_clamscan "$scan_dir" "$scan_dir" || { fail "Security scan failed."; exit 2; }
    echo ""
    ok "All scans complete."
    exit 0
}

handle_curl() {
    local output_path
    output_path="$(curl_output_path "$@")"

    if [[ -z "$output_path" ]]; then
        # No file output (stdout or no -o/-O), run directly without scanning
        command curl "$@"
        exit $?
    fi

    log "Running: curl $*"
    command curl "$@"
    local exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        fail "curl failed (exit ${exit_code})"
        exit $exit_code
    fi

    echo ""
    log "Download complete — scanning '${output_path}'..."
    echo ""

    run_clamscan "$output_path" "$output_path" || { fail "Security scan failed."; exit 2; }
    echo ""
    ok "All scans complete."
    exit 0
}

handle_wget() {
    local scan_target
    scan_target="$(wget_scan_target "$@")"

    if [[ -z "$scan_target" ]]; then
        # Writing to stdout, run directly
        command wget "$@"
        exit $?
    fi

    log "Running: wget $*"
    command wget "$@"
    local exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        fail "wget failed (exit ${exit_code})"
        exit $exit_code
    fi

    echo ""
    log "Download complete — scanning '${scan_target}'..."
    echo ""

    run_clamscan "$scan_target" "$scan_target" || { fail "Security scan failed."; exit 2; }
    echo ""
    ok "All scans complete."
    exit 0
}

handle_tar() {
    local target_dir
    target_dir="$(tar_target_dir "$@")"

    log "Running: tar $*"
    command tar "$@"
    local exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        fail "tar failed (exit ${exit_code})"
        exit $exit_code
    fi

    echo ""
    log "Extraction complete — scanning '${target_dir}'..."
    echo ""

    run_clamscan "$target_dir" "$target_dir" || { fail "Security scan failed."; exit 2; }
    echo ""
    ok "All scans complete."
    exit 0
}

handle_unzip() {
    local target_dir
    target_dir="$(unzip_target_dir "$@")"

    log "Running: unzip $*"
    command unzip "$@"
    local exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        fail "unzip failed (exit ${exit_code})"
        exit $exit_code
    fi

    echo ""
    log "Extraction complete — scanning '${target_dir}'..."
    echo ""

    run_clamscan "$target_dir" "$target_dir" || { fail "Security scan failed."; exit 2; }
    echo ""
    ok "All scans complete."
    exit 0
}

handle_7z() {
    local target_dir
    target_dir="$(sevenz_target_dir "$@")"

    log "Running: ${MANAGER} $*"
    command "$MANAGER" "$@"
    local exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        fail "${MANAGER} failed (exit ${exit_code})"
        exit $exit_code
    fi

    echo ""
    log "Extraction complete — scanning '${target_dir}'..."
    echo ""

    run_clamscan "$target_dir" "$target_dir" || { fail "Security scan failed."; exit 2; }
    echo ""
    ok "All scans complete."
    exit 0
}

is_install_cmd() {
    local manager="$1"
    local cmd="$2"
    case "$manager:$cmd" in
        npm:install|npm:i|npm:ci|npm:update|npm:up)       return 0 ;;
        composer:install|composer:update|composer:require) return 0 ;;
    esac
    return 1
}

# ── Main ──────────────────────────────────────────────────────────────────────

if [[ $# -lt 1 ]]; then
    echo "Usage: sentinel <command> [args...]"
    echo "Run 'sentinel --help' for more information."
    exit 1
fi

MANAGER="$1"
shift

case "$MANAGER" in
    -h|--help)
        cat <<'EOF'
sentinel — malware scanner for package installs, downloads, and archives

Usage:
  sentinel <command> [args...]

Commands:
  npm <install|i|ci|update|up> [args...]   Scan node_modules after install
  composer <install|update|require> [args...] Scan vendor/ after install
  git clone <url> [dir]                    Scan cloned directory
  git pull / git fetch                     Scan current directory
  curl -o <file> <url>                     Scan downloaded file
  wget <url>                               Scan downloaded file
  tar xf <archive> [-C <dir>]             Scan extraction directory
  unzip <archive> [-d <dir>]              Scan extraction directory
  7z x <archive> [-o<dir>]               Scan extraction directory

Environment variables:
  SENTINEL_QUARANTINE   Directory for quarantined files (default: /tmp/sentinel-quarantine)
  SENTINEL_CLAM_OPTS    Custom flags passed to clamscan (overrides all defaults)
  SENTINEL_SKIP_CLAM    Set to 1 to skip ClamAV scanning
  SENTINEL_SKIP_AUDIT   Set to 1 to skip npm/composer audit

Exit codes:
  0  Clean
  1  The wrapped command itself failed
  2  Malware detected — infected files quarantined

See README.md for full documentation.
EOF
        exit 0
        ;;
    git)          handle_git "$@" ;;
    curl)         handle_curl "$@" ;;
    wget)         handle_wget "$@" ;;
    tar)          handle_tar "$@" ;;
    unzip)        handle_unzip "$@" ;;
    7z|7za)       handle_7z "$@" ;;
    npm|composer) ;;
    *)
        echo "Unsupported: $MANAGER (supported: npm, composer, git, curl, wget, tar, unzip, 7z, 7za)"
        exit 1
        ;;
esac

# Snapshot time before the manager runs so we can detect files written to
# public/ by post-install scripts (e.g. php artisan filament:upgrade).
INSTALL_TIMESTAMP=""
if is_install_cmd "$MANAGER" "${1:-}"; then
    INSTALL_TIMESTAMP="$(mktemp)"
fi

log "Running: ${MANAGER} $*"
"$MANAGER" "$@"
CMD_EXIT=$?

if [[ $CMD_EXIT -ne 0 ]]; then
    fail "${MANAGER} command failed (exit ${CMD_EXIT})"
    exit $CMD_EXIT
fi

if ! is_install_cmd "$MANAGER" "${1:-}"; then
    exit 0
fi

echo ""
log "Package installation detected — running security scans..."
echo ""

SCAN_FAILED=0

case "$MANAGER" in
    npm)
        run_clamscan "./node_modules" "node_modules" || SCAN_FAILED=1
        scan_npm_project_files "$INSTALL_TIMESTAMP" || SCAN_FAILED=1
        run_npm_audit || true
        ;;
    composer)
        run_clamscan "./vendor" "vendor" || SCAN_FAILED=1
        scan_composer_scripts || SCAN_FAILED=1
        scan_composer_project_files "$INSTALL_TIMESTAMP" || SCAN_FAILED=1
        run_composer_audit || true
        ;;
esac

[[ -n "$INSTALL_TIMESTAMP" ]] && rm -f "$INSTALL_TIMESTAMP"

echo ""
if [[ $SCAN_FAILED -eq 1 ]]; then
    fail "Security scan failed — review issues above before using these packages."
    exit 2
else
    ok "All scans complete."
fi
