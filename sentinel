handle_bash() {
    # Find the script argument: first non-option arg (or after --)
    # Bail out early if -c is present (inline command, not a file to scan)
    local script="" before=() after=() found=0 skip_next=0

    for arg in "$@"; do
        if [[ $found -eq 1 ]]; then
            after+=("$arg")
            continue
        fi
        if [[ $skip_next -eq 1 ]]; then
            before+=("$arg")
            skip_next=0
            continue
        fi
        case "$arg" in
            -c)
                # Inline command string — no script file to scan, pass through
                command bash "$@"
                exit $?
                ;;
            -o)
                # -o takes an option name value
                before+=("$arg")
                skip_next=1
                ;;
            --)
                before+=("$arg")
                # Everything after -- is script + args; grab next iteration as script
                found=2  # signal: next non-flag is the script after --
                ;;
            -*)
                before+=("$arg")
                ;;
            *)
                script="$arg"
                found=1
                ;;
        esac
    done

    # No script file — interactive or stdin mode, pass through
    if [[ -z "$script" ]]; then
        command bash "$@"
        exit $?
    fi

    # Process substitution: bash <(curl ...) passes /dev/fd/NN, /proc/self/fd/NN,
    # or a named pipe (FIFO) on systems that use those for process substitution.
    if [[ "$script" == /dev/fd/* ]] || [[ "$script" == /proc/self/fd/* ]] || [[ -p "$script" ]]; then
        local tmp
        tmp="$(mktemp /tmp/sentinel-bash-XXXXXX.sh)"
        log "Process substitution detected — scanning script before execution..."
        echo ""
        # Read the fd content into a temp file (the fd may already hold scanned
        # content if it came through our curl wrapper)
        cat "$script" > "$tmp" 2>/dev/null || {
            rm -f "$tmp"
            warn "Could not read process substitution fd — passing through"
            command bash "$@"
            exit $?
        }
        run_clamscan "$tmp" "bash process substitution" \
            || { fail "Security scan failed."; rm -f "$tmp"; exit 2; }
        echo ""
        ok "Scan clean — executing script."
        echo ""
        # Run with temp file so stdin stays attached to the terminal
        command bash "${before[@]+"${before[@]}"}" "$tmp" "${after[@]+"${after[@]}"}"
        local ret=$?
        rm -f "$tmp"
        exit $ret
    fi

    # Regular script file
    if [[ -f "$script" ]]; then
        echo ""
        log "Scanning script '${script}' before execution..."
        echo ""
        run_clamscan "$script" "$script" || { fail "Security scan failed."; exit 2; }
        echo ""
        ok "Scan clean — executing script."
        echo ""
        command bash "$@"
        exit $?
    fi

    # Script not found or other special case — pass through
    command bash "$@"
    exit $?
}

is_install_cmd() {
    local manager="$1"
    local cmd="$2"
    case "$manager:$cmd" in
        npm:install|npm:i|npm:ci|npm:update|npm:up)       return 0 ;;
        composer:install|composer:update|composer:require) return 0 ;;
    esac
    return 1
}

# ── Main ──────────────────────────────────────────────────────────────────────

if [[ $# -lt 1 ]]; then
    echo "Usage: sentinel <command> [args...]"
    echo "Run 'sentinel --help' for more information."
    exit 1
fi

MANAGER="$1"
shift

case "$MANAGER" in
    -h|--help)
        cat <<'EOF'
sentinel — malware scanner for package installs, downloads, and archives

Usage:
  sentinel <command> [args...]

Commands:
  npm <install|i|ci|update|up> [args...]      Scan node_modules after install
  composer <install|update|require> [args...]  Scan vendor/ after install
  git clone <url> [dir]                        Scan cloned directory
  git pull / git fetch                         Scan current directory
  curl -o <file> <url>                         Scan downloaded file
  wget <url>                                   Scan downloaded file
  bash <(curl -fsSL <url>)                     Scan script before execution (stdin stays as terminal)
  bash script.sh                               Scan script file before execution
  tar xf <archive> [-C <dir>]                 Scan extraction directory
  unzip <archive> [-d <dir>]                  Scan extraction directory
  7z x <archive> [-o<dir>]                    Scan extraction directory
  update                                       Update sentinel to the latest version
  uninstall                                    Remove sentinel and its shell wrappers

Environment variables:
  SENTINEL_QUARANTINE   Directory for quarantined files (default: /tmp/sentinel-quarantine)
  SENTINEL_CLAM_OPTS    Custom flags passed to clamscan (overrides all defaults)
  SENTINEL_SKIP_CLAM    Set to 1 to skip ClamAV scanning
  SENTINEL_SKIP_AUDIT   Set to 1 to skip npm/composer audit

Exit codes:
  0  Clean
  1  The wrapped command itself failed
  2  Malware detected — infected files quarantined

See README.md for full documentation.
EOF
        exit 0
        ;;
    uninstall)
        UNINSTALL_URL="https://raw.githubusercontent.com/geodro/sentinel/main/uninstall.sh"
        echo "[sentinel] Starting uninstall..."
        TMP="$(mktemp /tmp/sentinel-uninstall.XXXXXX.sh)"
        trap 'rm -f "$TMP"' EXIT
        if command -v curl &>/dev/null; then
            command curl -fsSL "$UNINSTALL_URL" -o "$TMP"
        elif command -v wget &>/dev/null; then
            command wget -qO "$TMP" "$UNINSTALL_URL"
        else
            echo "[sentinel] Error: curl or wget is required to uninstall."
            exit 1
        fi
        exec bash "$TMP"
        ;;
    update)
        INSTALL_URL="https://raw.githubusercontent.com/geodro/sentinel/main/install.sh"
        echo "[sentinel] Updating sentinel..."
        # Download install.sh to a temp file then exec it, replacing this process.
        # This avoids bash re-reading the sentinel file after install.sh overwrites it.
        TMP="$(mktemp /tmp/sentinel-install.XXXXXX.sh)"
        trap 'rm -f "$TMP"' EXIT
        if command -v curl &>/dev/null; then
            command curl -fsSL "$INSTALL_URL" -o "$TMP"
        elif command -v wget &>/dev/null; then
            command wget -qO "$TMP" "$INSTALL_URL"
        else
            echo "[sentinel] Error: curl or wget is required to update sentinel."
            exit 1
        fi
        exec bash "$TMP"
        ;;
    git)          handle_git "$@" ;;
    curl)         handle_curl "$@" ;;
    wget)         handle_wget "$@" ;;
    bash)         handle_bash "$@" ;;
    tar)          handle_tar "$@" ;;
    unzip)        handle_unzip "$@" ;;
    7z|7za)       handle_7z "$@" ;;
    npm|composer) ;;
    *)
        echo "Unsupported: $MANAGER (supported: npm, composer, git, curl, wget, bash, tar, unzip, 7z, 7za)"
        exit 1
        ;;
esac

# Snapshot time before the manager runs so we can detect files written to
# public/ by post-install scripts (e.g. php artisan filament:upgrade).
INSTALL_TIMESTAMP=""
if is_install_cmd "$MANAGER" "${1:-}"; then
    INSTALL_TIMESTAMP="$(mktemp)"
fi

log "Running: ${MANAGER} $*"
"$MANAGER" "$@"
CMD_EXIT=$?

if [[ $CMD_EXIT -ne 0 ]]; then
    fail "${MANAGER} command failed (exit ${CMD_EXIT})"
    exit $CMD_EXIT
fi

if ! is_install_cmd "$MANAGER" "${1:-}"; then
    exit 0
fi

echo ""
log "Package installation detected — running security scans..."
echo ""

SCAN_FAILED=0

case "$MANAGER" in
    npm)
        run_clamscan "./node_modules" "node_modules" || SCAN_FAILED=1
        scan_npm_project_files "$INSTALL_TIMESTAMP" || SCAN_FAILED=1
        run_npm_audit || true
        ;;
    composer)
        run_clamscan "./vendor" "vendor" || SCAN_FAILED=1
        scan_composer_scripts || SCAN_FAILED=1
        scan_composer_project_files "$INSTALL_TIMESTAMP" || SCAN_FAILED=1
        run_composer_audit || true
        ;;
esac

[[ -n "$INSTALL_TIMESTAMP" ]] && rm -f "$INSTALL_TIMESTAMP"

echo ""
if [[ $SCAN_FAILED -eq 1 ]]; then
    fail "Security scan failed — review issues above before using these packages."
    exit 2
else
    ok "All scans complete."
fi
